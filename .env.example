# Copie para ".env" na pasta do package.json. Sem aspas nas chaves.

# Google Gemini (https://aistudio.google.com/apikey) — pode esgotar cota no plano grátis
# GEMINI_API_KEY=AIzaSy...
GEMINI_API_KEY=

# Groq — gratuito, com visão: https://console.groq.com/keys
# Se a cota do Gemini acabar, com MEAL_ANALYSIS_PROVIDER=auto o servidor usa Groq automaticamente.
# GROQ_API_KEY=gsk_...
GROQ_API_KEY=

# auto (padrão) | gemini | groq
MEAL_ANALYSIS_PROVIDER=auto

# Modelo Groq com imagem (opcional)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Um modelo Gemini ou vários separados por vírgula (tenta o seguinte se der 404)
GEMINI_MODEL=gemini-2.0-flash

PORT=3000
