# Copie para ".env" na pasta do package.json. Sem aspas nas chaves.

# --- Google Gemini (análise real da foto) ---
# Chave da API: https://aistudio.google.com/apikey (Google AI Studio)
#
# "Gemini Advanced" / Google One (app gemini.google.com) NÃO substitui esta chave:
#   o Daia usa a API de programador, não o login do chat.
#
# Para cotas maiores (uso pago, estilo "Pro" na API): no Google Cloud, ative faturação
# no MESMO projeto associado à sua chave do AI Studio — veja ai.google.dev e a consola Cloud.
#
# GEMINI_API_KEY=AIzaSy...
GEMINI_API_KEY=

# Forçar só Gemini (recomendado se só usas esta chave paga):
# MEAL_ANALYSIS_PROVIDER=gemini
#
# Modelo com mais capacidade (pode exigir plano com faturação; veja lista em ai.google.dev):
# GEMINI_MODEL=gemini-2.5-pro
# Ou mais rápido: gemini-2.5-flash / gemini-2.0-flash (padrão abaixo)

# Groq — gratuito, com visão: https://console.groq.com/keys
# Se a cota do Gemini acabar, com MEAL_ANALYSIS_PROVIDER=auto o servidor usa Groq automaticamente.
# GROQ_API_KEY=gsk_...
GROQ_API_KEY=

# auto (padrão) | gemini | groq | claude
MEAL_ANALYSIS_PROVIDER=auto

# Anthropic Claude — visão (JPEG/PNG/GIF/WebP; não HEIC)
# https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...
# Modelo opcional (veja docs da Anthropic se o padrão não existir na sua conta)
# CLAUDE_MODEL=claude-sonnet-4-6

# Modelo Groq com imagem (opcional)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Um modelo ou vários separados por vírgula (o servidor tenta o seguinte se der 404)
GEMINI_MODEL=gemini-2.0-flash

# --- Deploy (site + API no mesmo domínio) ---
# Recomendado: https://render.com → New Web Service → repo GitHub com esta pasta na raiz.
# Build: npm install | Start: npm start | Variáveis: copia as chaves acima (GEMINI_API_KEY, …).
# O ficheiro render.yaml preenche build/start; define as secrets no painel Environment.
# URL pública: HTTPS — o fluxo de câmara/análise funciona como em localhost.
# Só simulação: ?live=0 na URL ou localStorage daia_live_api = "0"

PORT=3000
